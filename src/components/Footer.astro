---
import type { Locale } from '../config/site';
import { t } from '../i18n/ui';

interface Props {
  locale: Locale;
  affiliateUrl: string;
}

const { locale, affiliateUrl } = Astro.props;
const L = t(locale);
---

<footer class="site-footer">
  <div class="wrap footer-grid">
    <div>
      <p class="age-badge" aria-label="18+">18+</p>
      <p class="footer-note" style="margin-top:0.75rem">{L.footerResponsible}</p>
      <p class="footer-note">{L.footerDisclaimer}</p>
    </div>
    <div class="footer-links">
      <a href={`/${locale}/privacy/`}>{L.footerPrivacy}</a>
      <a href={`/${locale}/terms/`}>{L.footerTerms}</a>
      <a href={`/${locale}/faq/`}>FAQ</a>
      <a href={affiliateUrl} rel="nofollow sponsored noopener" target="_blank">1win</a>
    </div>
    <div class="footer-links">
      <a href={`/${locale}/demo/`}>Demo</a>
      <a href={`/${locale}/strategy/`}>Strategy</a>
      <a href={`/${locale}/bonus/`}>Bonus</a>
      <a href={`/${locale}/blog/`}>Blog</a>
    </div>
  </div>
</footer>
