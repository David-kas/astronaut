---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RocketHero from '../../components/RocketHero.astro';
import PageSections from '../../components/PageSections.astro';
import { getHome } from '../../data/registry';
import { renderRelatedAside } from '../../data/renderRelated';
import { AFFILIATE_URL, LOCALES, type Locale } from '../../config/site';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const locale = lang as Locale;
const page = getHome(locale);
const relatedHtml = renderRelatedAside(locale, 'home');
const crumbs = [{ name: locale === 'ru' ? 'Главная' : 'Home', path: '/' }];
---

<BaseLayout
  locale={locale}
  title={page.title}
  description={page.description}
  canonicalPath="/"
  keywords={page.keywords}
  faqItems={page.faq}
  breadcrumbs={crumbs}
>
  <RocketHero
    locale={locale}
    affiliateUrl={AFFILIATE_URL}
    h1={page.h1}
    lead={page.lead ?? ''}
  />
  <PageSections
    locale={locale}
    affiliateUrl={AFFILIATE_URL}
    sections={page.sections}
    faq={page.faq}
    relatedHtml={relatedHtml}
  />
</BaseLayout>
